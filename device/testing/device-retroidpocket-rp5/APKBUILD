# Reference: <https://postmarketos.org/devicepkg>
# Contributor: Alexey Andreyev <dev@aa13q.ru>
pkgname=device-retroidpocket-rp5
pkgdesc="Retroid Pocket 5"
pkgver=1
pkgrel=6
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
# pmb:strict is required for grub
options="!check !archcheck pmb:strict"
depends="
	postmarketos-base
	systemd-boot
"
makedepends="
	devicepkg-dev
	dtc
	grub
	grub-efi
"
source="deviceinfo modules-initfs.mainline sm8250-retroidpocket-rp5-empty.dts
	qcom-gpu-firmware.files
	$pkgname.post-install
	ucm/HiFi-RP.conf
	ucm/RetroidPocket.conf
	ucm/wsa881x-init.conf
	99-retroid-gamepad.rules
	fancontrol.sh
	fancontrol.service
	phoc.ini
	rp5-orientation.sh
	rp5-orientation.desktop
	dconf-profile-user
	dconf-osk
	dconf-osk-lock
	analog-mouse.py
	analog-mouse.service
	uinput-load.conf
	$pkgname-phosh.post-install
"
install="$pkgname.post-install"
# TODO: 	$pkgname-kernel-mainline:kernel_mainline
subpackages="
	$pkgname-kernel-downstream:kernel_downstream
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-phosh:phosh
"

build() {
	devicepkg_build $startdir $pkgname
	grub-mkimage \
		--prefix="/grub" \
		--output="$srcdir/bootaa64.efi" \
		--format="arm64-efi" \
		--compression="xz" \
		\
		all_video \
		cat \
		configfile \
		disk \
		echo \
		efi_gop \
		fat \
		gzio \
		help \
		iso9660 \
		linux \
		ls \
		normal \
		part_gpt \
		part_msdos \
		search \
		search_label \
		test \
		true
}

package() {
	devicepkg_package $startdir $pkgname

	# Grub / bootloader
	install -Dm644 -t "$pkgdir"/boot/EFI/Boot \
		"$srcdir"/bootaa64.efi

	# Install post-install script
	install -Dm755 "$srcdir"/$pkgname.post-install \
		"$pkgdir"/usr/share/post-install/$pkgname.post-install

	# ALSA UCM config (author: Teguh Sobirin <teguh@sobir.in>)
	install -Dm644 -t "$pkgdir"/usr/share/alsa/ucm2/Qualcomm/sm8250 \
		"$srcdir"/HiFi-RP.conf \
		"$srcdir"/RetroidPocket.conf
	install -Dm644 "$srcdir"/wsa881x-init.conf \
		"$pkgdir"/usr/share/alsa/ucm2/codecs/wsa881x/init.conf
	mkdir -p "$pkgdir"/usr/share/alsa/ucm2/conf.d/sm8250
	ln -s /usr/share/alsa/ucm2/Qualcomm/sm8250/RetroidPocket.conf \
		"$pkgdir"/usr/share/alsa/ucm2/conf.d/sm8250/retroidpocket-RetroidPocket5-.conf

	# Gamepad udev rule (source: Batocera/ROCKNIX)
	install -Dm644 "$srcdir"/99-retroid-gamepad.rules \
		"$pkgdir"/usr/lib/udev/rules.d/99-retroid-gamepad.rules

	# Fan control (source: JELOS/ROCKNIX)
	install -Dm755 "$srcdir"/fancontrol.sh \
		"$pkgdir"/usr/bin/fancontrol
	install -Dm644 "$srcdir"/fancontrol.service \
		"$pkgdir"/usr/lib/systemd/system/fancontrol.service
}

kernel_downstream() {
	pkgdesc="Downstream kernel (recommended, close to mainline until not upstreamed)"
	depends="linux-retroidpocket-rp5"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_mainline() {
	pkgdesc="Mainline kernel (not recommended yet)"
	depends="linux-postmarketos-qcom-sm8250"

	dtc -O dtb -o "$srcdir/dtbo.img" -I dts "$srcdir/sm8250-retroidpocket-rp5-empty.dts"
	install -Dm644 "$srcdir/dtbo.img" "$subpkgdir/boot/dtbo.img"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

nonfree_firmware() {
	pkgdesc="GPU, Modem, DSP, WiFi, Bluetooth and other firmware"
	depends="
		firmware-qcom-adreno-a650
		firmware-qcom-sm8250
		linux-firmware-qcom
		linux-firmware-ath11k
		linux-firmware-rtl_nic
		linux-firmware-qca
		pd-mapper
		tqftpserv
	"
	mkdir "$subpkgdir"

	# Install mkinitfs hook to include GPU firmware in initramfs
	install -Dm644 "$srcdir"/qcom-gpu-firmware.files \
		"$subpkgdir"/etc/mkinitfs/files/qcom-gpu-firmware.files
}

phosh() {
	install_if="$pkgname postmarketos-ui-phosh"
	pkgdesc="Phosh tweaks for the Retroid Pocket 5 (orientation, scale, OSK, gamepad-as-mouse)"
	depends="wlr-randr dconf py3-evdev"
	install="$subpkgname.post-install"

	# Compositor scale (rotation is handled by the wlr-randr autostart below
	# because phoc.ini "rotate" is overridden by the DRM panel-orientation).
	install -Dm644 "$srcdir"/phoc.ini "$subpkgdir"/etc/phosh/phoc.ini

	# Orientation helper: force upright landscape (transform 90) + 1.75 scale.
	install -Dm755 "$srcdir"/rp5-orientation.sh "$subpkgdir"/usr/bin/rp5-orientation

	# Autostart it in the user session, the phrog greeter, and for new users.
	install -Dm644 "$srcdir"/rp5-orientation.desktop \
		"$subpkgdir"/etc/xdg/autostart/rp5-orientation.desktop
	install -Dm644 "$srcdir"/rp5-orientation.desktop \
		"$subpkgdir"/etc/phrog/autostart/rp5-orientation.desktop
	install -Dm644 "$srcdir"/rp5-orientation.desktop \
		"$subpkgdir"/etc/skel/.config/autostart/rp5-orientation.desktop

	# Keep the on-screen keyboard available (phosh resets it) via a dconf lock.
	install -Dm644 "$srcdir"/dconf-profile-user "$subpkgdir"/etc/dconf/profile/user
	install -Dm644 "$srcdir"/dconf-osk "$subpkgdir"/etc/dconf/db/local.d/00-osk
	install -Dm644 "$srcdir"/dconf-osk-lock \
		"$subpkgdir"/etc/dconf/db/local.d/locks/00-osk

	# Gamepad-as-mouse: phosh/Wayland ignores the gamepad for UI, so map the
	# left analog stick to the pointer (A = left-click, B = right-click) via
	# an evdev->uinput daemon. Needs the uinput module loaded at boot.
	install -Dm755 "$srcdir"/analog-mouse.py "$subpkgdir"/usr/bin/rp5-analog-mouse
	install -Dm644 "$srcdir"/analog-mouse.service \
		"$subpkgdir"/usr/lib/systemd/system/analog-mouse.service
	install -Dm644 "$srcdir"/uinput-load.conf \
		"$subpkgdir"/usr/lib/modules-load.d/uinput.conf
	# Statically enable the service (no systemctl at image-build time).
	mkdir -p "$subpkgdir"/etc/systemd/system/multi-user.target.wants
	ln -s /usr/lib/systemd/system/analog-mouse.service \
		"$subpkgdir"/etc/systemd/system/multi-user.target.wants/analog-mouse.service
}

