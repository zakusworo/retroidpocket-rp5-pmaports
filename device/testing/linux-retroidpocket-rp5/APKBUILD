# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config based on: arch/arm64/configs/vendor/kona_defconfig

pkgname=linux-retroidpocket-rp5
pkgver=6.17.0
pkgrel=6
pkgdesc="Retroid Pocket 5 kernel fork"
arch="aarch64"
_carch="arm64"
_flavor="retroidpocket-rp5"
url="https://kernel.org"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	devicepkg-dev
	dtc
	flex
	linux-headers
	openssl-dev
	perl
	python3
	xz
"

# Source
_host="gitlab.postmarketos.org"
_repository="soc/qualcomm-sm8250/linux"
_tag="sm8250-$pkgver"
_config="config-$_flavor.$arch"

source="
	$pkgname-$_tag.tar.gz::https://$_host/$_repository/-/archive/$_tag/linux-$_tag.tar.gz
	$_config
	0000-sm8250-retroidpocket-common.patch
	0004-pm8150b-haptics.patch
	0005-sm8250-uart.patch
	0007-panel-ddic-ch13726a.patch
	0008-retroid-gamepad.patch
	0009-qcom-spmi-haptics.patch
	0010-leds-htr3212.patch
	0012-ASoC-qcom-q6asm-dai-Change-some-default-periods.patch
	0013-add-force-feedback.patch
	0014-fix-wifi-and-bt-mac.patch
	0016-fix-vol-up-with-custom-uboot.patch
	0017-drm-panel-ddic-ch13726a-add-support-for-rpminiv2.patch
	0020-panel-ddic-ch13726a-dsi-init.patch
	0021-arm64-dts-qcom-sm8250-retroidpocket-fan-cooling-maps.patch
	0022-charger-fix-online-detection.patch
	0023-qcom-fg-charger-status-live-read.patch
	0018-arm64-dts-qcom-sm8250-add-support-for-Retroid-Pocket.patch
	0019-arm64-dts-qcom-sm8250-add-support-for-Retroid-Pocket.patch
	9997-set-boot-fanspeed.patch
	9998-gpu-opp-table.patch
	9999-remove-log-spam.patch
"
builddir="$srcdir/linux-$_tag"
_outdir="out"

prepare() {
	default_prepare
	REPLACE_GCCH=0 . downstreamkernel_prepare
	ln -sf "$builddir/$_outdir/kernel" "$builddir/kernel"
}

build() {
	unset LDFLAGS
	make O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS" \
		V=1
}

package() {
	downstreamkernel_package \
		"$builddir" "$pkgdir" "$_carch" "$_flavor" "$_outdir"

	make O="$_outdir" \
		ARCH="$_carch" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_MOD_PATH="$pkgdir" \
		modules_install

	make O="$_outdir" \
		ARCH="$_carch" \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs" \
		dtbs_install
}

